# Alfcolab HEAD — environment variables
# Copy this file to ".env" for local dev, or set these in your host (Vercel).
# These are PUBLIC values safe to expose in the client (the "anon" key is
# designed to be public — security is enforced by Supabase Row Level Security).

# Supabase project — optional for the current MVP.
# When set, the development-status app pages read the session and reveal links
# to authenticated users. When unset, those pages show the restricted-access
# screen for everyone (safe default).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
